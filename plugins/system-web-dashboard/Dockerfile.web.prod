# -- Stage 1: build the Vite React bundle --
# Build context = repo root, so we mirror the monorepo layout under /work
# (the package.json references @teamagentica/api-client via
# `file:../../../packages/api-client`, so the api-client must sit at the
# matching relative path inside the container).
FROM node:22-alpine AS builder
WORKDIR /work
COPY packages/api-client ./packages/api-client
COPY plugins/system-web-dashboard/web ./plugins/system-web-dashboard/web
WORKDIR /work/plugins/system-web-dashboard/web
RUN npm ci
RUN npm run build

# -- Stage 2: nginx runtime --
FROM nginx:alpine
COPY plugins/system-web-dashboard/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /work/plugins/system-web-dashboard/web/dist /usr/share/nginx/html
EXPOSE 3000
CMD ["nginx", "-g", "daemon off;"]
