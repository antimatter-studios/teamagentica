# Roboslop Configuration
# Copy this to .env and fill in your values

# === REQUIRED ===

# JWT signing secret (generate with: openssl rand -hex 32)
ROBOSLOP_JWT_SECRET=

# === OPTIONAL (defaults shown) ===

# Kernel
ROBOSLOP_KERNEL_HOST=0.0.0.0
ROBOSLOP_KERNEL_PORT=8080
ROBOSLOP_DB_PATH=./roboslop.db
ROBOSLOP_DOCKER_NETWORK=roboslop_default
ROBOSLOP_MTLS_ENABLED=true

# Address plugins use to reach the kernel (in Docker: container name)
ROBOSLOP_KERNEL_ADVERTISE_HOST=kernel

# Frontend (build-time Vite vars)
VITE_ROBOSLOP_KERNEL_HOST=localhost
VITE_ROBOSLOP_KERNEL_PORT=8080
