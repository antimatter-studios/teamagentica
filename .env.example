# TeamAgentica Configuration
# Copy this to .env and fill in your values

# === BRAND NAME ===
APP_NAME=TeamAgentica

# === REQUIRED ===

# === OPTIONAL (defaults shown) ===

# Kernel
TEAMAGENTICA_KERNEL_HOST=0.0.0.0
TEAMAGENTICA_KERNEL_PORT=8080
TEAMAGENTICA_DB_PATH=./data/kernel/database.db
TEAMAGENTICA_DATA_DIR=./data
TEAMAGENTICA_DOCKER_NETWORK=teamagentica_default
TEAMAGENTICA_MTLS_ENABLED=true

# Address plugins use to reach the kernel (in Docker: container name)
TEAMAGENTICA_KERNEL_ADVERTISE_HOST=kernel

# Frontend (build-time Vite vars)
VITE_APP_NAME=TeamAgentica
VITE_TEAMAGENTICA_KERNEL_HOST=localhost
VITE_TEAMAGENTICA_KERNEL_PORT=9741
